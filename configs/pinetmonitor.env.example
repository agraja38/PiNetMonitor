# PiNetMonitor supports a production inline gateway deployment with two Ethernet ports:
# one WAN-facing port to the upstream router/modem and one LAN-facing port to your switch/AP side.
PINETMONITOR_HTTP_ADDR=0.0.0.0:8080
PINETMONITOR_DB_PATH=/var/lib/pinetmonitor/pinetmonitor.db
PINETMONITOR_FRONTEND_DIR=/opt/pinetmonitor/web/dist
PINETMONITOR_SAMPLE_INTERVAL=30s
PINETMONITOR_WAN_IFACE=eth0
PINETMONITOR_LAN_IFACE=eth1
# Use a downstream subnet that is different from your upstream WAN subnet.
PINETMONITOR_LAN_CIDR=192.168.50.0/24
PINETMONITOR_GATEWAY_MODE=true
PINETMONITOR_ENABLE_NAT=true
PINETMONITOR_ENABLE_HTTPS_ATTRIBUTION=true
PINETMONITOR_GITHUB_USERNAME=agraja38
PINETMONITOR_GITHUB_REPOSITORY=agraja38/PiNetMonitor
# Export the token outside this file before using pinetmonitor update.
# Example: export GITHUB_ACCESS_TOKEN=your-token
GITHUB_ACCESS_TOKEN=
